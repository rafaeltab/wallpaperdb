# These values are for host-based development (running services directly on the host).
# For Docker-based development, run `pnpm install` to generate .env files with
# Docker-internal hostnames and worktree-specific ports via scripts/setup-worktree.mjs.
# Do not edit the generated .env files directly - they will be regenerated on install.

# Server Configuration
PORT=3001
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://wallpaperdb:wallpaperdb@localhost:5432/wallpaperdb_ingestor

# MinIO (S3-compatible object storage)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=wallpapers
S3_REGION=us-east-1

# NATS
NATS_URL=nats://localhost:4222
NATS_STREAM=WALLPAPER

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_ENABLED=true

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=ingestor

# Clerk (authentication)
CLERK_DOMAIN=https://your-clerk-instance.clerk.accounts.dev
