{
  "name": "@wallpaperdb/web-e2e",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "test:unit": "vitest run test",
    "test:e2e": "node --experimental-strip-types ./src/verify-environment.ts && playwright test --config playwright.config.ts --pass-with-no-tests",
    "test:e2e:ui": "node --experimental-strip-types ./src/verify-environment.ts && playwright test --config playwright.config.ts --ui --pass-with-no-tests",
    "test:e2e:headed": "node --experimental-strip-types ./src/verify-environment.ts && playwright test --config playwright.config.ts --headed --pass-with-no-tests",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check --write .",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@playwright/test": "^1.51.1",
    "@types/node": "^24.10.1",
    "dotenv": "^16.4.7",
    "typescript": "~5.9.3",
    "vitest": "^3.0.0"
  }
}
