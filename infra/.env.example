# PostgreSQL Configuration
POSTGRES_DB=wallpaperdb
POSTGRES_USER=wallpaperdb
POSTGRES_PASSWORD=wallpaperdb

# MinIO Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# pgAdmin Configuration
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin

# Grafana LGTM Configuration
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# OpenSearch Configuration
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=admin

# Docker Compose Project Name
# Overridden by scripts/setup-worktree.mjs based on branch name.
COMPOSE_PROJECT_NAME=wallpaperdb

# Host port assignments
# All overridden by scripts/setup-worktree.mjs based on the worktree slot.
# Slot 0 (main): base 8000  →  ports 8000–8007
# Slot 1:        base 8010  →  ports 8010–8017
# Slot N:        base 8000 + N*10
INGRESS_PORT=8000
POSTGRES_HOST_PORT=8001
MINIO_API_HOST_PORT=8002
NATS_HOST_PORT=8003
REDIS_HOST_PORT=8004
OPENSEARCH_HOST_PORT=8005
OTEL_HTTP_HOST_PORT=8006
OTEL_GRPC_HOST_PORT=8007
