{
  "name": "@wallpaperdb/auth",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Authentication abstractions and Clerk JWT verification for WallpaperDB services",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@clerk/fastify": "^3.1.19",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0"
  },
  "peerDependencies": {
    "@wallpaperdb/core": "workspace:*",
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@types/node": "^22.10.2",
    "@wallpaperdb/vitest-config": "workspace:*",
    "fastify": "^5.0.0",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  }
}
