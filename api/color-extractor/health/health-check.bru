meta {
  name: Health Check
  type: http
  seq: 1
}

get {
  url: {{colorExtractorBaseUrl}}/health
  body: none
  auth: none
}

docs {
  Check if the service is healthy (all dependencies operational).

  Returns 200 if healthy, 503 if unhealthy.

  Response includes status of:
  - minio (S3 storage)
  - nats (message queue)
  - otel (OpenTelemetry)
}
