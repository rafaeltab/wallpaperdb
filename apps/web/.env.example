# These values are for host-based development (running services directly on the host).
# For Docker-based development, run `pnpm install` to generate .env files with
# worktree-specific ports via scripts/setup-worktree.mjs.
# Do not edit the generated .env files directly - they will be regenerated on install.

# Base path for sub-path deployments (e.g. /web when behind Caddy).
# Leave empty or set to / for host-based development.
VITE_BASE_PATH=

# Gateway GraphQL API URL
VITE_GATEWAY_URL=http://localhost:3004/graphql

# Ingestor REST API URL
VITE_INGESTOR_URL=http://localhost:3001
